      "textIndopak": "ثُمَّ رَدَدۡنٰهُ اَسۡفَلَ سَافِلِيۡنَۙ‏",
      "words": [
        {
          "position": 1,
          "textUthmani": "ثُمَّ",
          "transliteration": "thumma",
          "translation": "Then",
          "audioUrl": "https://audio.qurancdn.com/wbw/095_005_001.mp3",
          "charType": "word"
        },
        {
          "position": 2,
          "textUthmani": "رَدَدْنَـٰهُ",
          "transliteration": "radadnāhu",
          "translation": "We returned him",
          "audioUrl": "https://audio.qurancdn.com/wbw/095_005_002.mp3",
          "charType": "word"
        },
        {
          "position": 3,
          "textUthmani": "أَسْفَلَ",
          "transliteration": "asfala",
          "translation": "(to the) lowest",
          "audioUrl": "https://audio.qurancdn.com/wbw/095_005_003.mp3",
          "charType": "word"
        },
        {
          "position": 4,
          "textUthmani": "سَـٰفِلِينَ",
          "transliteration": "sāfilīna",
          "translation": "(of the) low",
          "audioUrl": "https://audio.qurancdn.com/wbw/095_005_004.mp3",
          "charType": "word"
        },
        {
          "position": 5,
          "textUthmani": "٥",
          "transliteration": null,
          "translation": "(5)",
          "audioUrl": null,
          "charType": "end"
        }
      ],
      "translation": "Then We return him to the lowest of the low,",
      "transliteration": "Thumma ra-dad-naahu asfala saafileen",
      "audioUrl": "https://everyayah.com/data/Alafasy_128kbps/095005.mp3"
    },
    {
      "number": 6,
      "key": "95:6",
      "textUthmani": "إِلَّا ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّـٰلِحَـٰتِ فَلَهُمْ أَجْرٌ غَيْرُ مَمْنُونٍ",
      "textUthmaniTajweed": "إِلَّا <tajweed class=ham_wasl>ٱ</tajweed>لَّذِينَ ءَامَنُو<tajweed class=slnt>اْ</tajweed> وَعَمِلُو<tajweed class=slnt>اْ</tajweed> <tajweed class=ham_wasl>ٱ</tajweed><tajweed class=laam_shamsiyah>ل</tajweed>صَّ<tajweed class=madda_normal>ـٰ</tajweed>لِحَ<tajweed class=madda_normal>ـٰ</tajweed>تِ فَلَهُمْ أَ<tajweed class=qalaqah>جْ</tajweed>رٌ غَيْرُ مَمْن<tajweed class=madda_permissible>ُو</tajweed>نٍ <span class=end>٦</span>",
      "textIndopak": "اِلَّا الَّذِيۡنَ اٰمَنُوۡا وَعَمِلُوا الصّٰلِحٰتِ فَلَهُمۡ اَجۡرٌ غَيۡرُ مَمۡنُوۡنٍؕ‏",
      "words": [
        {
          "position": 1,
          "textUthmani": "إِلَّا",
          "transliteration": "illā",
          "translation": "Except",
          "audioUrl": "https://audio.qurancdn.com/wbw/095_006_001.mp3",
          "charType": "word"
        },
        {
          "position": 2,
          "textUthmani": "ٱلَّذِينَ",
          "transliteration": "alladhīna",
          "translation": "those who",
          "audioUrl": "https://audio.qurancdn.com/wbw/095_006_002.mp3",
          "charType": "word"
        },
        {
          "position": 3,
          "textUthmani": "ءَامَنُوا۟",
          "transliteration": "āmanū",
          "translation": "believe",
          "audioUrl": "https://audio.qurancdn.com/wbw/095_006_003.mp3",
          "charType": "word"
        },
        {
          "position": 4,
          "textUthmani": "وَعَمِلُوا۟",
          "transliteration": "waʿamilū",
          "translation": "and do",
          "audioUrl": "https://audio.qurancdn.com/wbw/095_006_004.mp3",
          "charType": "word"
        },
        {
          "position": 5,
          "textUthmani": "ٱلصَّـٰلِحَـٰتِ",
          "transliteration": "l-ṣāliḥāti",
          "translation": "righteous deeds",
          "audioUrl": "https://audio.qurancdn.com/wbw/095_006_005.mp3",
          "charType": "word"
        },
        {
          "position": 6,
          "textUthmani": "فَلَهُمْ",
          "transliteration": "falahum",
          "translation": "then for them",
          "audioUrl": "https://audio.qurancdn.com/wbw/095_006_006.mp3",
          "charType": "word"
        },
        {
          "position": 7,
          "textUthmani": "أَجْرٌ",
          "transliteration": "ajrun",
          "translation": "(is a) reward",
          "audioUrl": "https://audio.qurancdn.com/wbw/095_006_007.mp3",
          "charType": "word"
        },
        {
          "position": 8,
          "textUthmani": "غَيْرُ",
          "transliteration": "ghayru",
          "translation": "never",
          "audioUrl": "https://audio.qurancdn.com/wbw/095_006_008.mp3",
          "charType": "word"
        },
        {
          "position": 9,
          "textUthmani": "مَمْنُونٍۢ",
          "transliteration": "mamnūnin",
          "translation": "ending",
          "audioUrl": "https://audio.qurancdn.com/wbw/095_006_009.mp3",
          "charType": "word"
        },
        {
          "position": 10,
          "textUthmani": "٦",
          "transliteration": null,
          "translation": "(6)",
          "audioUrl": null,
          "charType": "end"
        }
      ],
      "translation": "Except for those who believe and do righteous deeds, for they will have a reward uninterrupted.",
      "transliteration": "Ill-lal lazeena aamanoo Wa-'amilus saalihaati; falahum ajrun ghairu mamnoon",
      "audioUrl": "https://everyayah.com/data/Alafasy_128kbps/095006.mp3"
    },
    {
      "number": 7,
      "key": "95:7",
      "textUthmani": "فَمَا يُكَذِّبُكَ بَعْدُ بِٱلدِّينِ",
      "textUthmaniTajweed": "فَمَا يُكَذِّبُكَ بَعْدُ بِ<tajweed class=ham_wasl>ٱ</tajweed><tajweed class=laam_shamsiyah>ل</tajweed>دّ<tajweed class=madda_permissible>ِي</tajweed>نِ <span class=end>٧</span>",
      "textIndopak": "فَمَا يُكَذِّبُكَ بَعۡدُ بِالدِّيۡنِ‏",
      "words": [
        {
          "position": 1,
          "textUthmani": "فَمَا",
          "transliteration": "famā",
          "translation": "Then what",
          "audioUrl": "https://audio.qurancdn.com/wbw/095_007_001.mp3",
          "charType": "word"
        },
        {
          "position": 2,
          "textUthmani": "يُكَذِّبُكَ",
          "transliteration": "yukadhibuka",
          "translation": "causes you to deny",
          "audioUrl": "https://audio.qurancdn.com/wbw/095_007_002.mp3",
          "charType": "word"
        },
        {
          "position": 3,
          "textUthmani": "بَعْدُ",
          "transliteration": "baʿdu",
          "translation": "after (this)",
          "audioUrl": "https://audio.qurancdn.com/wbw/095_007_003.mp3",
          "charType": "word"
        },
        {
          "position": 4,
          "textUthmani": "بِٱلدِّينِ",
          "transliteration": "bil-dīni",
          "translation": "the judgment",
          "audioUrl": "https://audio.qurancdn.com/wbw/095_007_004.mp3",
          "charType": "word"
        },
        {
          "position": 5,
          "textUthmani": "٧",
          "transliteration": null,
          "translation": "(7)",
          "audioUrl": null,
          "charType": "end"
        }
      ],
      "translation": "So what yet causes you to deny the Recompense?",
      "transliteration": "Fama yu-kaz-zibuka b'adu bid-deen",
      "audioUrl": "https://everyayah.com/data/Alafasy_128kbps/095007.mp3"
    },
    {
      "number": 8,
      "key": "95:8",
      "textUthmani": "أَلَيْسَ ٱللَّهُ بِأَحْكَمِ ٱلْحَـٰكِمِينَ",
      "textUthmaniTajweed": "أَلَيْسَ <tajweed class=ham_wasl>ٱ</tajweed>للَّهُ بِأَحْكَمِ <tajweed class=ham_wasl>ٱ</tajweed>لْحَ<tajweed class=madda_normal>ـٰ</tajweed>كِم<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>٨</span>",
      "textIndopak": "اَلَيۡسَ اللّٰهُ بِاَحۡكَمِ الۡحٰكِمِيۡنَ‏",
      "words": [
        {
