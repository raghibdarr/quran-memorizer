          "charType": "word"
        },
        {
          "position": 2,
          "textUthmani": "ٱللَّهُ",
          "transliteration": "l-lahu",
          "translation": "Allah",
          "audioUrl": "https://audio.qurancdn.com/wbw/095_008_002.mp3",
          "charType": "word"
        },
        {
          "position": 3,
          "textUthmani": "بِأَحْكَمِ",
          "transliteration": "bi-aḥkami",
          "translation": "(the) Most Just",
          "audioUrl": "https://audio.qurancdn.com/wbw/095_008_003.mp3",
          "charType": "word"
        },
        {
          "position": 4,
          "textUthmani": "ٱلْحَـٰكِمِينَ",
          "transliteration": "l-ḥākimīna",
          "translation": "(of) the Judges",
          "audioUrl": "https://audio.qurancdn.com/wbw/095_008_004.mp3",
          "charType": "word"
        },
        {
          "position": 5,
          "textUthmani": "٨",
          "transliteration": null,
          "translation": "(8)",
          "audioUrl": null,
          "charType": "end"
        }
      ],
      "translation": "Is not Allāh the most just of judges?",
      "transliteration": "Alai-sal laahu bi-ahkamil haakimeen",
