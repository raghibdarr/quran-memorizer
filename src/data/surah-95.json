          "transliteration": null,
          "translation": "(4)",
          "audioUrl": null,
          "charType": "end"
        }
      ],
      "translation": "We have certainly created man in the best of stature;",
      "transliteration": "Laqad khalaqnal insaana fee ahsani taqweem",
      "audioUrl": "https://everyayah.com/data/Alafasy_128kbps/095004.mp3"
    },
    {
      "number": 5,
      "key": "95:5",
      "textUthmani": "ثُمَّ رَدَدْنَـٰهُ أَسْفَلَ سَـٰفِلِينَ",
