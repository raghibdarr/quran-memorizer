    },
    {
      "number": 3,
      "key": "95:3",
      "textUthmani": "وَهَـٰذَا ٱلْبَلَدِ ٱلْأَمِينِ",
      "textUthmaniTajweed": "وَهَ<tajweed class=madda_normal>ـٰ</tajweed>ذَا <tajweed class=ham_wasl>ٱ</tajweed>لْبَلَدِ <tajweed class=ham_wasl>ٱ</tajweed>لْأَم<tajweed class=madda_permissible>ِي</tajweed>نِ <span class=end>٣</span>",
      "textIndopak": "وَهٰذَا الۡبَلَدِ الۡاَمِيۡنِۙ‏",
      "words": [
        {
          "position": 1,
          "textUthmani": "وَهَـٰذَا",
          "transliteration": "wahādhā",
          "translation": "And this",
          "audioUrl": "https://audio.qurancdn.com/wbw/095_003_001.mp3",
          "charType": "word"
        },
        {
          "position": 2,
          "textUthmani": "ٱلْبَلَدِ",
          "transliteration": "l-baladi",
          "translation": "[the] city",
          "audioUrl": "https://audio.qurancdn.com/wbw/095_003_002.mp3",
          "charType": "word"
        },
        {
          "position": 3,
          "textUthmani": "ٱلْأَمِينِ",
          "transliteration": "l-amīni",
          "translation": "[the] secure",
