    },
    {
      "number": 4,
      "key": "95:4",
      "textUthmani": "لَقَدْ خَلَقْنَا ٱلْإِنسَـٰنَ فِىٓ أَحْسَنِ تَقْوِيمٍ",
      "textUthmaniTajweed": "لَقَ<tajweed class=qalaqah>دْ</tajweed> خَلَ<tajweed class=qalaqah>قْ</tajweed>نَا <tajweed class=ham_wasl>ٱ</tajweed>لْإِ<tajweed class=ikhafa>نس</tajweed>َ<tajweed class=madda_normal>ـٰ</tajweed>نَ ف<tajweed class=madda_obligatory>ِىٓ</tajweed> أَحْسَنِ تَ<tajweed class=qalaqah>قْ</tajweed>و<tajweed class=madda_permissible>ِي</tajweed>مٍ <span class=end>٤</span>",
      "textIndopak": "لَقَدۡ خَلَقۡنَا الۡاِنۡسَانَ فِىۡۤ اَحۡسَنِ تَقۡوِيۡمٍ‏",
      "words": [
        {
          "position": 1,
          "textUthmani": "لَقَدْ",
          "transliteration": "laqad",
          "translation": "Indeed",
          "audioUrl": "https://audio.qurancdn.com/wbw/095_004_001.mp3",
          "charType": "word"
        },
        {
          "position": 2,
          "textUthmani": "خَلَقْنَا",
          "transliteration": "khalaqnā",
          "translation": "We created",
          "audioUrl": "https://audio.qurancdn.com/wbw/095_004_002.mp3",
          "charType": "word"
        },
        {
          "position": 3,
          "textUthmani": "ٱلْإِنسَـٰنَ",
          "transliteration": "l-insāna",
          "translation": "man",
          "audioUrl": "https://audio.qurancdn.com/wbw/095_004_003.mp3",
          "charType": "word"
        },
        {
          "position": 4,
          "textUthmani": "فِىٓ",
          "transliteration": "fī",
          "translation": "in",
          "audioUrl": "https://audio.qurancdn.com/wbw/095_004_004.mp3",
          "charType": "word"
        },
        {
          "position": 5,
          "textUthmani": "أَحْسَنِ",
          "transliteration": "aḥsani",
          "translation": "(the) best",
          "audioUrl": "https://audio.qurancdn.com/wbw/095_004_005.mp3",
          "charType": "word"
        },
        {
          "position": 6,
          "textUthmani": "تَقْوِيمٍۢ",
          "transliteration": "taqwīmin",
          "translation": "mould",
          "audioUrl": "https://audio.qurancdn.com/wbw/095_004_006.mp3",
          "charType": "word"
        },
        {
          "position": 7,
