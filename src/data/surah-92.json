      "textIndopak": "فَاَنۡذَرۡتُكُمۡ نَارًا تَلَظّٰى​ۚ‏",
      "words": [
        {
          "position": 1,
          "textUthmani": "فَأَنذَرْتُكُمْ",
          "transliteration": "fa-andhartukum",
