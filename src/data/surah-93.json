    },
    {
      "number": 2,
      "key": "93:2",
      "textUthmani": "وَٱلَّيْلِ إِذَا سَجَىٰ",
      "textUthmaniTajweed": "وَ<tajweed class=ham_wasl>ٱ</tajweed>لَّيْلِ إِذَا سَجَىٰ <span class=end>٢</span>",
