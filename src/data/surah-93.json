          "charType": "word"
        },
        {
          "position": 2,
          "textUthmani": "إِذَا",
          "transliteration": "idhā",
          "translation": "when",
          "audioUrl": "https://audio.qurancdn.com/wbw/093_002_002.mp3",
          "charType": "word"
        },
        {
          "position": 3,
          "textUthmani": "سَجَىٰ",
          "transliteration": "sajā",
          "translation": "it covers with darkness",
