      "textIndopak": "اَلَمۡ يَجِدۡكَ يَتِيۡمًا فَاٰوٰى‏",
      "words": [
        {
          "position": 1,
          "textUthmani": "أَلَمْ",
          "transliteration": "alam",
          "translation": "Did not",
          "audioUrl": "https://audio.qurancdn.com/wbw/093_006_001.mp3",
          "charType": "word"
        },
        {
          "position": 2,
          "textUthmani": "يَجِدْكَ",
          "transliteration": "yajid'ka",
          "translation": "He find you",
          "audioUrl": "https://audio.qurancdn.com/wbw/093_006_002.mp3",
          "charType": "word"
        },
        {
          "position": 3,
          "textUthmani": "يَتِيمًۭا",
