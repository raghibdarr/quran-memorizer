      "textIndopak": "وَوَجَدَكَ عَآٮِٕلًا فَاَغۡنٰىؕ‏",
      "words": [
        {
          "position": 1,
          "textUthmani": "وَوَجَدَكَ",
          "transliteration": "wawajadaka",
          "translation": "And He found you",
          "audioUrl": "https://audio.qurancdn.com/wbw/093_008_001.mp3",
          "charType": "word"
        },
        {
          "position": 2,
          "textUthmani": "عَآئِلًۭا",
          "transliteration": "ʿāilan",
          "translation": "in need",
          "audioUrl": "https://audio.qurancdn.com/wbw/093_008_002.mp3",
          "charType": "word"
        },
        {
          "position": 3,
          "textUthmani": "فَأَغْنَىٰ",
          "transliteration": "fa-aghnā",
          "translation": "so He made self-sufficient",
          "audioUrl": "https://audio.qurancdn.com/wbw/093_008_003.mp3",
          "charType": "word"
        },
        {
          "position": 4,
          "textUthmani": "٨",
          "transliteration": null,
          "translation": "(8)",
          "audioUrl": null,
          "charType": "end"
        }
      ],
      "translation": "And He found you poor and made [you] self-sufficient.",
      "transliteration": "Wa-Wa-jadaka 'aa-ilan fa-aghnaa",
      "audioUrl": "https://everyayah.com/data/Alafasy_128kbps/093008.mp3"
    },
    {
      "number": 9,
      "key": "93:9",
      "textUthmani": "فَأَمَّا ٱلْيَتِيمَ فَلَا تَقْهَرْ",
