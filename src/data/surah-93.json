          "textUthmani": "٢",
          "transliteration": null,
          "translation": "(2)",
          "audioUrl": null,
          "charType": "end"
        }
      ],
      "translation": "And [by] the night when it covers with darkness,",
      "transliteration": "Wal-laili itha sajaa",
      "audioUrl": "https://everyayah.com/data/Alafasy_128kbps/093002.mp3"
    },
    {
      "number": 3,
      "key": "93:3",
      "textUthmani": "مَا وَدَّعَكَ رَبُّكَ وَمَا قَلَىٰ",
      "textUthmaniTajweed": "مَا وَدَّعَكَ رَبُّكَ وَمَا قَلَىٰ <span class=end>٣</span>",
      "textIndopak": "مَا وَدَّعَكَ رَبُّكَ وَمَا قَلٰىؕ‏",
      "words": [
        {
          "position": 1,
          "textUthmani": "مَا",
          "transliteration": "mā",
          "translation": "Not",
          "audioUrl": "https://audio.qurancdn.com/wbw/093_003_001.mp3",
          "charType": "word"
        },
        {
          "position": 2,
          "textUthmani": "وَدَّعَكَ",
          "transliteration": "waddaʿaka",
          "translation": "has forsaken you",
          "audioUrl": "https://audio.qurancdn.com/wbw/093_003_002.mp3",
          "charType": "word"
        },
        {
          "position": 3,
          "textUthmani": "رَبُّكَ",
          "transliteration": "rabbuka",
          "translation": "your Lord",
          "audioUrl": "https://audio.qurancdn.com/wbw/093_003_003.mp3",
          "charType": "word"
        },
        {
          "position": 4,
          "textUthmani": "وَمَا",
          "transliteration": "wamā",
          "translation": "and not",
          "audioUrl": "https://audio.qurancdn.com/wbw/093_003_004.mp3",
          "charType": "word"
        },
        {
          "position": 5,
          "textUthmani": "قَلَىٰ",
          "transliteration": "qalā",
          "translation": "He is displeased",
          "audioUrl": "https://audio.qurancdn.com/wbw/093_003_005.mp3",
          "charType": "word"
        },
        {
          "position": 6,
          "textUthmani": "٣",
          "transliteration": null,
          "translation": "(3)",
          "audioUrl": null,
          "charType": "end"
        }
      ],
      "translation": "Your Lord has not taken leave of you, [O Muḥammad], nor has He detested [you].",
      "transliteration": "Ma wad-da'aka rabbuka Wa-ma qalaa",
      "audioUrl": "https://everyayah.com/data/Alafasy_128kbps/093003.mp3"
    },
    {
      "number": 4,
      "key": "93:4",
      "textUthmani": "وَلَلْـَٔاخِرَةُ خَيْرٌ لَّكَ مِنَ ٱلْأُولَىٰ",
      "textUthmaniTajweed": "وَلَلْأَخِرَةُ خَيْ<tajweed class=idgham_wo_ghunnah>رٌ ل</tajweed>َّكَ مِنَ <tajweed class=ham_wasl>ٱ</tajweed>لْأُولَىٰ <span class=end>٤</span>",
      "textIndopak": "وَلَـلۡاٰخِرَةُ خَيۡرٌ لَّكَ مِنَ الۡاُوۡلٰىؕ‏",
      "words": [
        {
          "position": 1,
          "textUthmani": "وَلَلْـَٔاخِرَةُ",
          "transliteration": "walalākhiratu",
          "translation": "And surely the Hereafter",
          "audioUrl": "https://audio.qurancdn.com/wbw/093_004_001.mp3",
          "charType": "word"
        },
        {
          "position": 2,
          "textUthmani": "خَيْرٌۭ",
          "transliteration": "khayrun",
          "translation": "(is) better",
          "audioUrl": "https://audio.qurancdn.com/wbw/093_004_002.mp3",
          "charType": "word"
        },
        {
          "position": 3,
          "textUthmani": "لَّكَ",
          "transliteration": "laka",
          "translation": "for you",
          "audioUrl": "https://audio.qurancdn.com/wbw/093_004_003.mp3",
          "charType": "word"
        },
        {
          "position": 4,
          "textUthmani": "مِنَ",
          "transliteration": "mina",
          "translation": "than",
          "audioUrl": "https://audio.qurancdn.com/wbw/093_004_004.mp3",
          "charType": "word"
        },
        {
          "position": 5,
          "textUthmani": "ٱلْأُولَىٰ",
          "transliteration": "l-ūlā",
          "translation": "the first",
          "audioUrl": "https://audio.qurancdn.com/wbw/093_004_005.mp3",
          "charType": "word"
        },
        {
          "position": 6,
          "textUthmani": "٤",
          "transliteration": null,
          "translation": "(4)",
          "audioUrl": null,
          "charType": "end"
        }
      ],
      "translation": "And the Hereafter is better for you than the first [life].",
      "transliteration": "Walal-aakhiratu khairul laka minal oola",
      "audioUrl": "https://everyayah.com/data/Alafasy_128kbps/093004.mp3"
    },
    {
      "number": 5,
      "key": "93:5",
      "textUthmani": "وَلَسَوْفَ يُعْطِيكَ رَبُّكَ فَتَرْضَىٰٓ",
      "textUthmaniTajweed": "وَلَسَوْفَ يُعْطِيكَ رَبُّكَ فَتَرْضَىٰٓ <span class=end>٥</span>",
      "textIndopak": "وَلَسَوۡفَ يُعۡطِيۡكَ رَبُّكَ فَتَرۡضٰىؕ‏",
      "words": [
        {
          "position": 1,
          "textUthmani": "وَلَسَوْفَ",
          "transliteration": "walasawfa",
          "translation": "And soon",
          "audioUrl": "https://audio.qurancdn.com/wbw/093_005_001.mp3",
          "charType": "word"
        },
        {
          "position": 2,
          "textUthmani": "يُعْطِيكَ",
          "transliteration": "yuʿ'ṭīka",
          "translation": "will give you",
          "audioUrl": "https://audio.qurancdn.com/wbw/093_005_002.mp3",
          "charType": "word"
        },
        {
          "position": 3,
          "textUthmani": "رَبُّكَ",
          "transliteration": "rabbuka",
          "translation": "your Lord",
          "audioUrl": "https://audio.qurancdn.com/wbw/093_005_003.mp3",
          "charType": "word"
        },
        {
          "position": 4,
          "textUthmani": "فَتَرْضَىٰٓ",
          "transliteration": "fatarḍā",
          "translation": "then you will be satisfied",
          "audioUrl": "https://audio.qurancdn.com/wbw/093_005_004.mp3",
          "charType": "word"
        },
        {
          "position": 5,
          "textUthmani": "٥",
          "transliteration": null,
          "translation": "(5)",
          "audioUrl": null,
          "charType": "end"
        }
      ],
      "translation": "And your Lord is going to give you, and you will be satisfied.",
      "transliteration": "Wa-la-sawfa y'uteeka rabbuka fatarda",
      "audioUrl": "https://everyayah.com/data/Alafasy_128kbps/093005.mp3"
    },
    {
      "number": 6,
      "key": "93:6",
      "textUthmani": "أَلَمْ يَجِدْكَ يَتِيمًا فَـَٔاوَىٰ",
