          "charType": "word"
        },
        {
          "position": 3,
          "textUthmani": "فَلَا",
          "transliteration": "falā",
          "translation": "then (do) not",
          "audioUrl": "https://audio.qurancdn.com/wbw/093_010_003.mp3",
          "charType": "word"
        },
        {
          "position": 4,
          "textUthmani": "تَنْهَرْ",
          "transliteration": "tanhar",
          "translation": "repel",
