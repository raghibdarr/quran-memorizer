          "textUthmani": "وَأَمَّا",
          "transliteration": "wa-ammā",
          "translation": "And as for",
          "audioUrl": "https://audio.qurancdn.com/wbw/093_010_001.mp3",
          "charType": "word"
        },
        {
          "position": 2,
          "textUthmani": "ٱلسَّآئِلَ",
          "transliteration": "l-sāila",
