      "words": [
        {
          "position": 1,
          "textUthmani": "فَأَمَّا",
          "transliteration": "fa-ammā",
          "translation": "So as for",
          "audioUrl": "https://audio.qurancdn.com/wbw/093_009_001.mp3",
          "charType": "word"
        },
        {
          "position": 2,
          "textUthmani": "ٱلْيَتِيمَ",
          "transliteration": "l-yatīma",
          "translation": "the orphan",
          "audioUrl": "https://audio.qurancdn.com/wbw/093_009_002.mp3",
          "charType": "word"
        },
        {
          "position": 3,
          "textUthmani": "فَلَا",
          "transliteration": "falā",
          "translation": "then (do) not",
          "audioUrl": "https://audio.qurancdn.com/wbw/093_009_003.mp3",
          "charType": "word"
        },
        {
          "position": 4,
          "textUthmani": "تَقْهَرْ",
          "transliteration": "taqhar",
          "translation": "oppress",
          "audioUrl": "https://audio.qurancdn.com/wbw/093_009_004.mp3",
          "charType": "word"
        },
        {
          "position": 5,
          "textUthmani": "٩",
          "transliteration": null,
          "translation": "(9)",
          "audioUrl": null,
          "charType": "end"
        }
      ],
      "translation": "So as for the orphan, do not oppress [him].",
      "transliteration": "Fa-am-mal yateema fala taqhar",
      "audioUrl": "https://everyayah.com/data/Alafasy_128kbps/093009.mp3"
    },
    {
      "number": 10,
      "key": "93:10",
      "textUthmani": "وَأَمَّا ٱلسَّآئِلَ فَلَا تَنْهَرْ",
