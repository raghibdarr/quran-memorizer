{
  "id": 82,
  "nameSimple": "Al-Infitar",
  "nameArabic": "الإنفطار",
  "nameTranslation": "The Cleaving",
  "revelationPlace": "makkah",
  "versesCount": 19,
  "ayahs": [
    {
      "number": 1,
      "key": "82:1",
      "textUthmani": " إِذَا ٱلسَّمَآءُ ٱنفَطَرَتْ",
      "textUthmaniTajweed": "إِذَا <tajweed class=ham_wasl>ٱ</tajweed><tajweed class=laam_shamsiyah>ل</tajweed>سَّم<tajweed class=madda_obligatory>َا</tajweed>ٓءُ <tajweed class=ham_wasl>ٱ</tajweed><tajweed class=ikhafa>نف</tajweed>َطَرَتْ <span class=end>١</span>",
      "textIndopak": "اِذَا السَّمَآءُ انْفَطَرَتۡۙ‏",
      "words": [
        {
          "position": 1,
          "textUthmani": "إِذَا",
          "transliteration": "idhā",
          "translation": "When",
          "audioUrl": "https://audio.qurancdn.com/wbw/082_001_001.mp3",
          "charType": "word"
        },
        {
          "position": 2,
          "textUthmani": "ٱلسَّمَآءُ",
          "transliteration": "l-samāu",
          "translation": "the sky",
          "audioUrl": "https://audio.qurancdn.com/wbw/082_001_002.mp3",
          "charType": "word"
        },
        {
          "position": 3,
          "textUthmani": "ٱنفَطَرَتْ",
          "transliteration": "infaṭarat",
          "translation": "(is) cleft asunder",
          "audioUrl": "https://audio.qurancdn.com/wbw/082_001_003.mp3",
          "charType": "word"
        },
        {
          "position": 4,
          "textUthmani": "١",
          "transliteration": null,
          "translation": "(1)",
          "audioUrl": null,
          "charType": "end"
        }
      ],
      "translation": "When the sky breaks apart",
      "transliteration": "Ithas samaaa'un fatarat",
      "audioUrl": "https://everyayah.com/data/Alafasy_128kbps/082001.mp3"
    },
    {
      "number": 2,
      "key": "82:2",
      "textUthmani": "وَإِذَا ٱلْكَوَاكِبُ ٱنتَثَرَتْ",
      "textUthmaniTajweed": "وَإِذَا <tajweed class=ham_wasl>ٱ</tajweed>لْكَوَاكِبُ <tajweed class=ham_wasl>ٱ</tajweed><tajweed class=ikhafa>نت</tajweed>َثَرَتْ <span class=end>٢</span>",
      "textIndopak": "وَاِذَا الۡكَوَاكِبُ انْتَثَرَتۡۙ‏",
      "words": [
        {
          "position": 1,
          "textUthmani": "وَإِذَا",
          "transliteration": "wa-idhā",
          "translation": "And when",
          "audioUrl": "https://audio.qurancdn.com/wbw/082_002_001.mp3",
          "charType": "word"
        },
        {
          "position": 2,
          "textUthmani": "ٱلْكَوَاكِبُ",
          "transliteration": "l-kawākibu",
          "translation": "the stars",
          "audioUrl": "https://audio.qurancdn.com/wbw/082_002_002.mp3",
          "charType": "word"
        },
        {
          "position": 3,
          "textUthmani": "ٱنتَثَرَتْ",
          "transliteration": "intatharat",
          "translation": "scatter",
          "audioUrl": "https://audio.qurancdn.com/wbw/082_002_003.mp3",
          "charType": "word"
        },
        {
          "position": 4,
          "textUthmani": "٢",
          "transliteration": null,
          "translation": "(2)",
          "audioUrl": null,
          "charType": "end"
        }
      ],
      "translation": "And when the stars fall, scattering,",
      "transliteration": "Wa-ithal kawaakibun tasarat",
      "audioUrl": "https://everyayah.com/data/Alafasy_128kbps/082002.mp3"
    },
    {
      "number": 3,
      "key": "82:3",
      "textUthmani": "وَإِذَا ٱلْبِحَارُ فُجِّرَتْ",
      "textUthmaniTajweed": "وَإِذَا <tajweed class=ham_wasl>ٱ</tajweed>لْبِحَارُ فُجِّرَتْ <span class=end>٣</span>",
      "textIndopak": "وَاِذَا الۡبِحَارُ فُجِّرَتۡۙ‏",
      "words": [
        {
          "position": 1,
          "textUthmani": "وَإِذَا",
          "transliteration": "wa-idhā",
          "translation": "And when",
          "audioUrl": "https://audio.qurancdn.com/wbw/082_003_001.mp3",
          "charType": "word"
        },
        {
          "position": 2,
          "textUthmani": "ٱلْبِحَارُ",
          "transliteration": "l-biḥāru",
          "translation": "the seas",
          "audioUrl": "https://audio.qurancdn.com/wbw/082_003_002.mp3",
          "charType": "word"
        },
        {
          "position": 3,
          "textUthmani": "فُجِّرَتْ",
          "transliteration": "fujjirat",
          "translation": "are made to gush forth",
          "audioUrl": "https://audio.qurancdn.com/wbw/082_003_003.mp3",
          "charType": "word"
        },
        {
          "position": 4,
          "textUthmani": "٣",
          "transliteration": null,
          "translation": "(3)",
          "audioUrl": null,
          "charType": "end"
        }
      ],
      "translation": "And when the seas are erupted",
      "transliteration": "Wa-ithal bihaaru fujjirat",
      "audioUrl": "https://everyayah.com/data/Alafasy_128kbps/082003.mp3"
    },
    {
      "number": 4,
      "key": "82:4",
      "textUthmani": "وَإِذَا ٱلْقُبُورُ بُعْثِرَتْ",
      "textUthmaniTajweed": "وَإِذَا <tajweed class=ham_wasl>ٱ</tajweed>لْقُبُورُ بُعْثِرَتْ <span class=end>٤</span>",
      "textIndopak": "وَاِذَا الۡقُبُوۡرُ بُعۡثِرَتۡۙ‏",
      "words": [
        {
          "position": 1,
          "textUthmani": "وَإِذَا",
          "transliteration": "wa-idhā",
          "translation": "And when",
          "audioUrl": "https://audio.qurancdn.com/wbw/082_004_001.mp3",
          "charType": "word"
        },
        {
          "position": 2,
          "textUthmani": "ٱلْقُبُورُ",
          "transliteration": "l-qubūru",
          "translation": "the graves",
          "audioUrl": "https://audio.qurancdn.com/wbw/082_004_002.mp3",
          "charType": "word"
        },
        {
          "position": 3,
          "textUthmani": "بُعْثِرَتْ",
          "transliteration": "buʿ'thirat",
          "translation": "are overturned",
          "audioUrl": "https://audio.qurancdn.com/wbw/082_004_003.mp3",
          "charType": "word"
        },
        {
          "position": 4,
          "textUthmani": "٤",
          "transliteration": null,
          "translation": "(4)",
          "audioUrl": null,
          "charType": "end"
        }
      ],
      "translation": "And when the [contents of] graves are scattered [i.e., exposed],",
      "transliteration": "Wa-ithal qubooru bu'sirat",
      "audioUrl": "https://everyayah.com/data/Alafasy_128kbps/082004.mp3"
    },
    {
      "number": 5,
      "key": "82:5",
      "textUthmani": "عَلِمَتْ نَفْسٌ مَّا قَدَّمَتْ وَأَخَّرَتْ",
      "textUthmaniTajweed": "عَلِمَتْ نَفْ<tajweed class=idgham_ghunnah>سٌ م</tajweed>َّا قَدَّمَتْ وَأَخَّرَتْ <span class=end>٥</span>",
      "textIndopak": "عَلِمَتۡ نَفۡسٌ مَّا قَدَّمَتۡ وَاَخَّرَتۡؕ‏",
      "words": [
        {
          "position": 1,
          "textUthmani": "عَلِمَتْ",
          "transliteration": "ʿalimat",
          "translation": "Will know",
          "audioUrl": "https://audio.qurancdn.com/wbw/082_005_001.mp3",
          "charType": "word"
        },
        {
          "position": 2,
          "textUthmani": "نَفْسٌۭ",
          "transliteration": "nafsun",
          "translation": "a soul",
          "audioUrl": "https://audio.qurancdn.com/wbw/082_005_002.mp3",
          "charType": "word"
        },
        {
          "position": 3,
          "textUthmani": "مَّا",
          "transliteration": "mā",
          "translation": "what",
          "audioUrl": "https://audio.qurancdn.com/wbw/082_005_003.mp3",
          "charType": "word"
        },
        {
          "position": 4,
          "textUthmani": "قَدَّمَتْ",
          "transliteration": "qaddamat",
          "translation": "it has sent forth",
          "audioUrl": "https://audio.qurancdn.com/wbw/082_005_004.mp3",
          "charType": "word"
        },
        {
          "position": 5,
          "textUthmani": "وَأَخَّرَتْ",
          "transliteration": "wa-akharat",
          "translation": "and left behind",
          "audioUrl": "https://audio.qurancdn.com/wbw/082_005_005.mp3",
          "charType": "word"
        },
        {
          "position": 6,
          "textUthmani": "٥",
          "transliteration": null,
          "translation": "(5)",
          "audioUrl": null,
          "charType": "end"
        }
      ],
      "translation": "A soul will [then] know what it has put forth and kept back.",
      "transliteration": "Alimat nafsum maa qaddamat Wa-akhkharat",
      "audioUrl": "https://everyayah.com/data/Alafasy_128kbps/082005.mp3"
    },
    {
      "number": 6,
      "key": "82:6",
      "textUthmani": "يَـٰٓأَيُّهَا ٱلْإِنسَـٰنُ مَا غَرَّكَ بِرَبِّكَ ٱلْكَرِيمِ",
      "textUthmaniTajweed": "يَ<tajweed class=madda_obligatory>ـٰٓ</tajweed>أَيُّهَا <tajweed class=ham_wasl>ٱ</tajweed>لْإِ<tajweed class=ikhafa>نس</tajweed>َ<tajweed class=madda_normal>ـٰ</tajweed>نُ مَا غَرَّكَ بِرَبِّكَ <tajweed class=ham_wasl>ٱ</tajweed>لْكَر<tajweed class=madda_permissible>ِي</tajweed>مِ <span class=end>٦</span>",
      "textIndopak": "يٰۤاَيُّهَا الۡاِنۡسَانُ مَا غَرَّكَ بِرَبِّكَ الۡكَرِيۡمِۙ‏",
      "words": [
        {
          "position": 1,
          "textUthmani": "يَـٰٓأَيُّهَا",
          "transliteration": "yāayyuhā",
          "translation": "O",
          "audioUrl": "https://audio.qurancdn.com/wbw/082_006_001.mp3",
          "charType": "word"
        },
        {
          "position": 2,
          "textUthmani": "ٱلْإِنسَـٰنُ",
          "transliteration": "l-insānu",
          "translation": "man",
          "audioUrl": "https://audio.qurancdn.com/wbw/082_006_002.mp3",
          "charType": "word"
        },
        {
          "position": 3,
          "textUthmani": "مَا",
          "transliteration": "mā",
          "translation": "What",
          "audioUrl": "https://audio.qurancdn.com/wbw/082_006_003.mp3",
          "charType": "word"
        },
        {
          "position": 4,
          "textUthmani": "غَرَّكَ",
          "transliteration": "gharraka",
          "translation": "has deceived you",
          "audioUrl": "https://audio.qurancdn.com/wbw/082_006_004.mp3",
          "charType": "word"
        },
        {
          "position": 5,
          "textUthmani": "بِرَبِّكَ",
          "transliteration": "birabbika",
          "translation": "concerning your Lord",
          "audioUrl": "https://audio.qurancdn.com/wbw/082_006_005.mp3",
          "charType": "word"
        },
        {
          "position": 6,
          "textUthmani": "ٱلْكَرِيمِ",
          "transliteration": "l-karīmi",
          "translation": "the Most Noble",
          "audioUrl": "https://audio.qurancdn.com/wbw/082_006_006.mp3",
          "charType": "word"
        },
        {
          "position": 7,
          "textUthmani": "٦",
          "transliteration": null,
          "translation": "(6)",
          "audioUrl": null,
          "charType": "end"
        }
      ],
      "translation": "O mankind, what has deceived you concerning your Lord, the Generous,",
      "transliteration": "Yaaa-ayyuhal insaaanu maa gharraka bi-Rabbikal kareem",
      "audioUrl": "https://everyayah.com/data/Alafasy_128kbps/082006.mp3"
    },
    {
      "number": 7,
      "key": "82:7",
      "textUthmani": "ٱلَّذِى خَلَقَكَ فَسَوَّىٰكَ فَعَدَلَكَ",
      "textUthmaniTajweed": "ٱلَّذِى خَلَقَكَ فَسَوَّ<tajweed class=madda_normal>ٮٰ</tajweed>كَ فَعَدَلَكَ <span class=end>٧</span>",
      "textIndopak": "الَّذِىۡ خَلَقَكَ فَسَوّٰٮكَ فَعَدَلَـكَۙ‏",
      "words": [
        {
          "position": 1,
          "textUthmani": "ٱلَّذِى",
          "transliteration": "alladhī",
          "translation": "Who",
          "audioUrl": "https://audio.qurancdn.com/wbw/082_007_001.mp3",
          "charType": "word"
        },
        {
          "position": 2,
          "textUthmani": "خَلَقَكَ",
          "transliteration": "khalaqaka",
          "translation": "created you",
          "audioUrl": "https://audio.qurancdn.com/wbw/082_007_002.mp3",
          "charType": "word"
        },
        {
          "position": 3,
          "textUthmani": "فَسَوَّىٰكَ",
          "transliteration": "fasawwāka",
          "translation": "then fashioned you",
          "audioUrl": "https://audio.qurancdn.com/wbw/082_007_003.mp3",
          "charType": "word"
        },
        {
          "position": 4,
          "textUthmani": "فَعَدَلَكَ",
          "transliteration": "faʿadalaka",
          "translation": "then balanced you",
          "audioUrl": "https://audio.qurancdn.com/wbw/082_007_004.mp3",
          "charType": "word"
        },
        {
          "position": 5,
          "textUthmani": "٧",
          "transliteration": null,
          "translation": "(7)",
          "audioUrl": null,
          "charType": "end"
        }
      ],
      "translation": "Who created you, proportioned you, and balanced you?",
      "transliteration": "Allathee khalaqaka fasaw-waaka fa'adalak",
      "audioUrl": "https://everyayah.com/data/Alafasy_128kbps/082007.mp3"
    },
    {
      "number": 8,
      "key": "82:8",
      "textUthmani": "فِىٓ أَىِّ صُورَةٍ مَّا شَآءَ رَكَّبَكَ",
      "textUthmaniTajweed": "ف<tajweed class=madda_obligatory>ِىٓ</tajweed> أَىِّ صُورَ<tajweed class=idgham_ghunnah>ةٍ م</tajweed>َّا ش<tajweed class=madda_obligatory>َا</tajweed>ٓءَ رَكَّبَكَ <span class=end>٨</span>",
      "textIndopak": "فِىۡۤ اَىِّ صُوۡرَةٍ مَّا شَآءَ رَكَّبَكَؕ‏",
      "words": [
        {
          "position": 1,
          "textUthmani": "فِىٓ",
          "transliteration": "fī",
          "translation": "In",
          "audioUrl": "https://audio.qurancdn.com/wbw/082_008_001.mp3",
          "charType": "word"
        },
        {
          "position": 2,
          "textUthmani": "أَىِّ",
          "transliteration": "ayyi",
          "translation": "whatever",
          "audioUrl": "https://audio.qurancdn.com/wbw/082_008_002.mp3",
          "charType": "word"
        },
        {
          "position": 3,
          "textUthmani": "صُورَةٍۢ",
          "transliteration": "ṣūratin",
          "translation": "form",
          "audioUrl": "https://audio.qurancdn.com/wbw/082_008_003.mp3",
          "charType": "word"
        },
        {
          "position": 4,
          "textUthmani": "مَّا",
          "transliteration": "mā",
          "translation": "what",
          "audioUrl": "https://audio.qurancdn.com/wbw/082_008_004.mp3",
          "charType": "word"
        },
        {
          "position": 5,
          "textUthmani": "شَآءَ",
          "transliteration": "shāa",
          "translation": "He willed",
          "audioUrl": "https://audio.qurancdn.com/wbw/082_008_005.mp3",
          "charType": "word"
        },
        {
          "position": 6,
          "textUthmani": "رَكَّبَكَ",
          "transliteration": "rakkabaka",
          "translation": "He assembled you",
          "audioUrl": "https://audio.qurancdn.com/wbw/082_008_006.mp3",
          "charType": "word"
        },
        {
          "position": 7,
          "textUthmani": "٨",
          "transliteration": null,
          "translation": "(8)",
          "audioUrl": null,
          "charType": "end"
        }
      ],
      "translation": "In whatever form He willed has He assembled you.",
      "transliteration": "Feee ayye sooratim maa shaaa'a rakkabak",
      "audioUrl": "https://everyayah.com/data/Alafasy_128kbps/082008.mp3"
    },
    {
      "number": 9,
      "key": "82:9",
      "textUthmani": "كَلَّا بَلْ تُكَذِّبُونَ بِٱلدِّينِ",
      "textUthmaniTajweed": "كَلَّا بَلْ تُكَذِّبُونَ بِ<tajweed class=ham_wasl>ٱ</tajweed><tajweed class=laam_shamsiyah>ل</tajweed>دّ<tajweed class=madda_permissible>ِي</tajweed>نِ <span class=end>٩</span>",
      "textIndopak": "كَلَّا بَلۡ تُكَذِّبُوۡنَ بِالدِّيۡنِۙ‏",
      "words": [
        {
          "position": 1,
          "textUthmani": "كَلَّا",
          "transliteration": "kallā",
          "translation": "Nay",
          "audioUrl": "https://audio.qurancdn.com/wbw/082_009_001.mp3",
          "charType": "word"
        },
        {
          "position": 2,
          "textUthmani": "بَلْ",
          "transliteration": "bal",
          "translation": "But",
          "audioUrl": "https://audio.qurancdn.com/wbw/082_009_002.mp3",
          "charType": "word"
        },
        {
          "position": 3,
          "textUthmani": "تُكَذِّبُونَ",
          "transliteration": "tukadhibūna",
          "translation": "you deny",
          "audioUrl": "https://audio.qurancdn.com/wbw/082_009_003.mp3",
          "charType": "word"
        },
        {
          "position": 4,
          "textUthmani": "بِٱلدِّينِ",
          "transliteration": "bil-dīni",
          "translation": "the Judgment",
          "audioUrl": "https://audio.qurancdn.com/wbw/082_009_004.mp3",
          "charType": "word"
        },
        {
          "position": 5,
          "textUthmani": "٩",
          "transliteration": null,
          "translation": "(9)",
          "audioUrl": null,
          "charType": "end"
        }
      ],
      "translation": "No! But you deny the Recompense.",
      "transliteration": "Kalla bal tukaththiboona bid-deen",
      "audioUrl": "https://everyayah.com/data/Alafasy_128kbps/082009.mp3"
    },
    {
      "number": 10,
      "key": "82:10",
      "textUthmani": "وَإِنَّ عَلَيْكُمْ لَحَـٰفِظِينَ",
      "textUthmaniTajweed": "وَإِ<tajweed class=ghunnah>نّ</tajweed>َ عَلَيْكُمْ لَحَ<tajweed class=madda_normal>ـٰ</tajweed>فِظ<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>١٠</span>",
      "textIndopak": "وَاِنَّ عَلَيۡكُمۡ لَحٰـفِظِيۡنَۙ‏",
      "words": [
        {
          "position": 1,
          "textUthmani": "وَإِنَّ",
          "transliteration": "wa-inna",
          "translation": "And indeed",
          "audioUrl": "https://audio.qurancdn.com/wbw/082_010_001.mp3",
          "charType": "word"
        },
        {
          "position": 2,
          "textUthmani": "عَلَيْكُمْ",
          "transliteration": "ʿalaykum",
          "translation": "over you",
          "audioUrl": "https://audio.qurancdn.com/wbw/082_010_002.mp3",
          "charType": "word"
        },
        {
          "position": 3,
          "textUthmani": "لَحَـٰفِظِينَ",
          "transliteration": "laḥāfiẓīna",
          "translation": "(are) surely guardians",
          "audioUrl": "https://audio.qurancdn.com/wbw/082_010_003.mp3",
