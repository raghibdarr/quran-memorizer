      "textIndopak": "فَاِنَّ مَعَ الۡعُسۡرِ يُسۡرًا ۙ‏",
      "words": [
        {
          "position": 1,
          "textUthmani": "فَإِنَّ",
          "transliteration": "fa-inna",
          "translation": "So indeed",
          "audioUrl": "https://audio.qurancdn.com/wbw/094_005_001.mp3",
          "charType": "word"
        },
        {
          "position": 2,
          "textUthmani": "مَعَ",
          "transliteration": "maʿa",
          "translation": "with",
          "audioUrl": "https://audio.qurancdn.com/wbw/094_005_002.mp3",
          "charType": "word"
        },
        {
          "position": 3,
          "textUthmani": "ٱلْعُسْرِ",
          "transliteration": "l-ʿus'ri",
          "translation": "the hardship",
