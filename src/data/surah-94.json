          "charType": "word"
        },
        {
          "position": 4,
          "textUthmani": "يُسْرًا",
          "transliteration": "yus'ran",
          "translation": "(is) ease",
          "audioUrl": "https://audio.qurancdn.com/wbw/094_005_004.mp3",
          "charType": "word"
        },
        {
          "position": 5,
          "textUthmani": "٥",
          "transliteration": null,
          "translation": "(5)",
          "audioUrl": null,
          "charType": "end"
        }
      ],
      "translation": "For indeed, with hardship [will be] ease [i.e., relief].",
      "transliteration": "Fa-inna ma'al usri yusra",
      "audioUrl": "https://everyayah.com/data/Alafasy_128kbps/094005.mp3"
    },
    {
      "number": 6,
      "key": "94:6",
      "textUthmani": "إِنَّ مَعَ ٱلْعُسْرِ يُسْرًا",
      "textUthmaniTajweed": "إِ<tajweed class=ghunnah>نّ</tajweed>َ مَعَ <tajweed class=ham_wasl>ٱ</tajweed>لْعُسْرِ يُسْرًا <span class=end>٦</span>",
      "textIndopak": "اِنَّ مَعَ الۡعُسۡرِ يُسۡرًا ؕ‏",
      "words": [
        {
          "position": 1,
          "textUthmani": "إِنَّ",
          "transliteration": "inna",
          "translation": "Indeed",
          "audioUrl": "https://audio.qurancdn.com/wbw/094_006_001.mp3",
          "charType": "word"
        },
        {
          "position": 2,
          "textUthmani": "مَعَ",
          "transliteration": "maʿa",
          "translation": "with",
          "audioUrl": "https://audio.qurancdn.com/wbw/094_006_002.mp3",
          "charType": "word"
        },
        {
          "position": 3,
          "textUthmani": "ٱلْعُسْرِ",
          "transliteration": "l-ʿus'ri",
          "translation": "the hardship",
          "audioUrl": "https://audio.qurancdn.com/wbw/094_006_003.mp3",
          "charType": "word"
        },
        {
          "position": 4,
          "textUthmani": "يُسْرًۭا",
          "transliteration": "yus'ran",
          "translation": "(is) ease",
          "audioUrl": "https://audio.qurancdn.com/wbw/094_006_004.mp3",
          "charType": "word"
        },
        {
          "position": 5,
          "textUthmani": "٦",
          "transliteration": null,
          "translation": "(6)",
          "audioUrl": null,
          "charType": "end"
        }
      ],
      "translation": "Indeed, with hardship [will be] ease.",
      "transliteration": "Inna ma'al 'usri yusra",
      "audioUrl": "https://everyayah.com/data/Alafasy_128kbps/094006.mp3"
    },
    {
      "number": 7,
      "key": "94:7",
      "textUthmani": "فَإِذَا فَرَغْتَ فَٱنصَبْ",
      "textUthmaniTajweed": "فَإِذَا فَرَغْتَ فَ<tajweed class=ham_wasl>ٱ</tajweed><tajweed class=ikhafa>نص</tajweed>َ<tajweed class=qalaqah>بْ</tajweed> <span class=end>٧</span>",
      "textIndopak": "فَاِذَا فَرَغۡتَ فَانۡصَبۡۙ‏",
      "words": [
        {
          "position": 1,
          "textUthmani": "فَإِذَا",
          "transliteration": "fa-idhā",
          "translation": "So when",
          "audioUrl": "https://audio.qurancdn.com/wbw/094_007_001.mp3",
          "charType": "word"
        },
        {
          "position": 2,
          "textUthmani": "فَرَغْتَ",
          "transliteration": "faraghta",
          "translation": "you have finished",
          "audioUrl": "https://audio.qurancdn.com/wbw/094_007_002.mp3",
          "charType": "word"
        },
        {
          "position": 3,
          "textUthmani": "فَٱنصَبْ",
          "transliteration": "fa-inṣab",
          "translation": "then labor hard",
          "audioUrl": "https://audio.qurancdn.com/wbw/094_007_003.mp3",
          "charType": "word"
        },
        {
          "position": 4,
          "textUthmani": "٧",
          "transliteration": null,
          "translation": "(7)",
          "audioUrl": null,
          "charType": "end"
        }
      ],
      "translation": "So when you have finished [your duties], then stand up [for worship].",
      "transliteration": "Fa-itha faragh-ta fansab",
      "audioUrl": "https://everyayah.com/data/Alafasy_128kbps/094007.mp3"
    },
    {
      "number": 8,
      "key": "94:8",
      "textUthmani": "وَإِلَىٰ رَبِّكَ فَٱرْغَب",
      "textUthmaniTajweed": "وَإِلَىٰ رَبِّكَ فَ<tajweed class=ham_wasl>ٱ</tajweed>رْغَ<tajweed class=qalaqah>ب</tajweed> <span class=end>٨</span>",
      "textIndopak": "وَاِلٰى رَبِّكَ فَارۡغَب‏",
      "words": [
        {
          "position": 1,
          "textUthmani": "وَإِلَىٰ",
          "transliteration": "wa-ilā",
          "translation": "And to",
          "audioUrl": "https://audio.qurancdn.com/wbw/094_008_001.mp3",
          "charType": "word"
        },
        {
          "position": 2,
          "textUthmani": "رَبِّكَ",
          "transliteration": "rabbika",
          "translation": "your Lord",
          "audioUrl": "https://audio.qurancdn.com/wbw/094_008_002.mp3",
          "charType": "word"
        },
        {
          "position": 3,
          "textUthmani": "فَٱرْغَب",
          "transliteration": "fa-ir'ghab",
