      "textIndopak": "الَّذِىۡۤ اَنۡقَضَ ظَهۡرَكَۙ‏",
      "words": [
        {
          "position": 1,
          "textUthmani": "ٱلَّذِىٓ",
          "transliteration": "alladhī",
          "translation": "Which",
          "audioUrl": "https://audio.qurancdn.com/wbw/094_003_001.mp3",
          "charType": "word"
        },
        {
          "position": 2,
          "textUthmani": "أَنقَضَ",
          "transliteration": "anqaḍa",
          "translation": "weighed upon",
          "audioUrl": "https://audio.qurancdn.com/wbw/094_003_002.mp3",
          "charType": "word"
        },
        {
          "position": 3,
          "textUthmani": "ظَهْرَكَ",
          "transliteration": "ẓahraka",
          "translation": "your back",
          "audioUrl": "https://audio.qurancdn.com/wbw/094_003_003.mp3",
          "charType": "word"
        },
        {
          "position": 4,
          "textUthmani": "٣",
          "transliteration": null,
          "translation": "(3)",
          "audioUrl": null,
          "charType": "end"
        }
      ],
      "translation": "Which had weighed upon your back",
      "transliteration": "Allathee anqada zahrak",
      "audioUrl": "https://everyayah.com/data/Alafasy_128kbps/094003.mp3"
    },
    {
      "number": 4,
      "key": "94:4",
      "textUthmani": "وَرَفَعْنَا لَكَ ذِكْرَكَ",
      "textUthmaniTajweed": "وَرَفَعْنَا لَكَ ذِكْرَكَ <span class=end>٤</span>",
      "textIndopak": "وَرَفَعۡنَا لَـكَ ذِكۡرَكَؕ‏",
      "words": [
        {
          "position": 1,
          "textUthmani": "وَرَفَعْنَا",
          "transliteration": "warafaʿnā",
          "translation": "And We raised high",
          "audioUrl": "https://audio.qurancdn.com/wbw/094_004_001.mp3",
          "charType": "word"
        },
        {
          "position": 2,
          "textUthmani": "لَكَ",
          "transliteration": "laka",
          "translation": "for you",
          "audioUrl": "https://audio.qurancdn.com/wbw/094_004_002.mp3",
          "charType": "word"
        },
        {
          "position": 3,
          "textUthmani": "ذِكْرَكَ",
          "transliteration": "dhik'raka",
          "translation": "your reputation",
          "audioUrl": "https://audio.qurancdn.com/wbw/094_004_003.mp3",
          "charType": "word"
        },
        {
          "position": 4,
          "textUthmani": "٤",
          "transliteration": null,
          "translation": "(4)",
          "audioUrl": null,
          "charType": "end"
        }
      ],
      "translation": "And raised high for you your repute.",
      "transliteration": "Wa-raf-'ana laka thikrak",
      "audioUrl": "https://everyayah.com/data/Alafasy_128kbps/094004.mp3"
    },
    {
      "number": 5,
      "key": "94:5",
      "textUthmani": "فَإِنَّ مَعَ ٱلْعُسْرِ يُسْرًا",
