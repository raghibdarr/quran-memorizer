{
  "id": 94,
  "nameSimple": "Ash-Sharh",
  "nameArabic": "الشرح",
  "nameTranslation": "The Relief",
  "revelationPlace": "makkah",
  "versesCount": 8,
  "ayahs": [
    {
      "number": 1,
      "key": "94:1",
      "textUthmani": " أَلَمْ نَشْرَحْ لَكَ صَدْرَكَ",
      "textUthmaniTajweed": "أَلَمْ نَشْرَحْ لَكَ صَ<tajweed class=qalaqah>دْ</tajweed>رَكَ <span class=end>١</span>",
      "textIndopak": "اَلَمۡ نَشۡرَحۡ لَـكَ صَدۡرَكَۙ‏",
      "words": [
        {
          "position": 1,
          "textUthmani": "أَلَمْ",
          "transliteration": "alam",
          "translation": "Have not",
          "audioUrl": "https://audio.qurancdn.com/wbw/094_001_001.mp3",
          "charType": "word"
        },
        {
          "position": 2,
          "textUthmani": "نَشْرَحْ",
          "transliteration": "nashraḥ",
          "translation": "We expanded",
          "audioUrl": "https://audio.qurancdn.com/wbw/094_001_002.mp3",
          "charType": "word"
        },
        {
          "position": 3,
          "textUthmani": "لَكَ",
          "transliteration": "laka",
          "translation": "for you",
          "audioUrl": "https://audio.qurancdn.com/wbw/094_001_003.mp3",
          "charType": "word"
        },
        {
          "position": 4,
          "textUthmani": "صَدْرَكَ",
          "transliteration": "ṣadraka",
          "translation": "your breast",
          "audioUrl": "https://audio.qurancdn.com/wbw/094_001_004.mp3",
          "charType": "word"
        },
        {
          "position": 5,
          "textUthmani": "١",
          "transliteration": null,
          "translation": "(1)",
          "audioUrl": null,
          "charType": "end"
        }
      ],
      "translation": "Did We not expand for you, [O Muḥammad], your breast?",
      "transliteration": "Alam nashrah laka sadrak",
      "audioUrl": "https://everyayah.com/data/Alafasy_128kbps/094001.mp3"
    },
    {
      "number": 2,
      "key": "94:2",
      "textUthmani": "وَوَضَعْنَا عَنكَ وِزْرَكَ",
      "textUthmaniTajweed": "وَوَضَعْنَا عَ<tajweed class=ikhafa>نك</tajweed>َ وِزْرَكَ <span class=end>٢</span>",
      "textIndopak": "وَوَضَعۡنَا عَنۡكَ وِزۡرَكَۙ‏",
      "words": [
        {
          "position": 1,
          "textUthmani": "وَوَضَعْنَا",
          "transliteration": "wawaḍaʿnā",
          "translation": "And We removed",
          "audioUrl": "https://audio.qurancdn.com/wbw/094_002_001.mp3",
          "charType": "word"
        },
        {
          "position": 2,
          "textUthmani": "عَنكَ",
          "transliteration": "ʿanka",
          "translation": "from you",
          "audioUrl": "https://audio.qurancdn.com/wbw/094_002_002.mp3",
          "charType": "word"
        },
        {
          "position": 3,
          "textUthmani": "وِزْرَكَ",
          "transliteration": "wiz'raka",
          "translation": "your burden",
          "audioUrl": "https://audio.qurancdn.com/wbw/094_002_003.mp3",
          "charType": "word"
        },
        {
          "position": 4,
          "textUthmani": "٢",
          "transliteration": null,
          "translation": "(2)",
          "audioUrl": null,
          "charType": "end"
        }
      ],
      "translation": "And We removed from you your burden",
      "transliteration": "Wa-Wa-d'ana 'anka wizrak",
      "audioUrl": "https://everyayah.com/data/Alafasy_128kbps/094002.mp3"
    },
    {
      "number": 3,
      "key": "94:3",
