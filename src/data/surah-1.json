          "position": 8,
          "textUthmani": "وَلَا",
          "transliteration": "walā",
          "translation": "and not",
          "audioUrl": "https://audio.qurancdn.com/wbw/001_007_008.mp3",
          "charType": "word"
        },
        {
          "position": 9,
          "textUthmani": "ٱلضَّآلِّينَ",
          "transliteration": "l-ḍālīna",
          "translation": "(of) those who go astray",
