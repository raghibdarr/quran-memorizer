          "charType": "word"
        },
        {
          "position": 2,
          "textUthmani": "ٱلَّذِى",
          "transliteration": "alladhī",
          "translation": "(is) the one who",
          "audioUrl": "https://audio.qurancdn.com/wbw/107_002_002.mp3",
          "charType": "word"
        },
        {
