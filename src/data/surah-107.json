          "charType": "word"
        },
        {
          "position": 2,
          "textUthmani": "ٱلَّذِى",
          "transliteration": "alladhī",
          "translation": "the one who",
          "audioUrl": "https://audio.qurancdn.com/wbw/107_001_002.mp3",
          "charType": "word"
        },
        {
